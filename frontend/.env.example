# JSON-RPC endpoint for local wallet connections (no MetaMask required).
# Defaults to the Hardhat node when unset.
VITE_RPC_URL=http://127.0.0.1:8545

# Contract addresses — copy from deployments.json after running deploy.js.
VITE_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
VITE_NFT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
